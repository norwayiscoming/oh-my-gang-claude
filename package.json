{
  "name": "oh-my-claude-gang",
  "displayName": "Oh My Claude Gang",
  "description": "Turn your team's Claude Code sessions into shared intelligence. Auto-track who's coding what, search across all sessions, prevent file conflicts — zero config.",
  "version": "0.2.0",
  "publisher": "NorwayIsHere",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/norwayiscoming/oh-my-gang-claude"
  },
  "homepage": "https://github.com/norwayiscoming/oh-my-gang-claude#readme",
  "bugs": {
    "url": "https://github.com/norwayiscoming/oh-my-gang-claude/issues"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other",
    "Machine Learning"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "claude-max",
    "ai",
    "collaboration",
    "team",
    "session",
    "multi-agent",
    "anthropic",
    "pair-programming"
  ],
  "galleryBanner": {
    "color": "#0a0a0f",
    "theme": "dark"
  },
  "icon": "media/icon.png",
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "shareMyClaudeMax.search",
        "title": "Search Sessions",
        "category": "Share My Claude Max",
        "icon": "$(search)"
      },
      {
        "command": "shareMyClaudeMax.who",
        "title": "Who's Working?",
        "category": "Share My Claude Max",
        "icon": "$(people)"
      },
      {
        "command": "shareMyClaudeMax.refresh",
        "title": "Refresh Sessions",
        "category": "Share My Claude Max",
        "icon": "$(refresh)"
      },
      {
        "command": "shareMyClaudeMax.reindex",
        "title": "Rebuild Search Index",
        "category": "Share My Claude Max"
      },
      {
        "command": "shareMyClaudeMax.identify",
        "title": "Set Your Identity",
        "category": "Share My Claude Max"
      },
      {
        "command": "shareMyClaudeMax.indexSessions",
        "title": "Index All Sessions",
        "category": "Share My Claude Max"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "shareMyClaudeMax",
          "title": "Share My Claude Max",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "shareMyClaudeMax": [
        {
          "id": "shareMyClaudeMax.sessions",
          "name": "Sessions",
          "type": "tree"
        },
        {
          "id": "shareMyClaudeMax.details",
          "name": "Details",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "Share My Claude Max",
      "properties": {
        "shareMyClaudeMax.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Share My Claude Max"
        },
        "shareMyClaudeMax.embedding.provider": {
          "type": "string",
          "default": "none",
          "enum": ["none", "openai", "ollama"],
          "description": "Embedding provider for semantic search (optional, Layer 3)"
        },
        "shareMyClaudeMax.embedding.model": {
          "type": "string",
          "default": "text-embedding-3-small",
          "description": "Embedding model name"
        },
        "shareMyClaudeMax.embedding.dimensions": {
          "type": "number",
          "default": 256,
          "description": "Embedding vector dimensions"
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "shareMyClaudeMax.search",
          "when": "view == shareMyClaudeMax.sessions",
          "group": "navigation"
        },
        {
          "command": "shareMyClaudeMax.refresh",
          "when": "view == shareMyClaudeMax.sessions",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "check-types": "tsc --noEmit",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "vscode-test",
    "pretest": "npm run compile"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@stylistic/eslint-plugin": "^2.9.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "^22",
    "@types/vscode": "^1.96.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "esbuild": "^0.25.0",
    "eslint": "^9.13.0",
    "mocha": "^10.2.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0"
  }
}
